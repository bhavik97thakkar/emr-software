{
  "name": "medcore-emr-unified",
  "version": "1.0.0",
  "description": "Unified MedCore EMR (Frontend + Backend)",
  "main": "server.js",
  "scripts": {
    "install-all": "npm install",
    "dev": "concurrently -n \"backend,frontend\" -c \"magenta,cyan\" \"node server.js\" \"vite --port 5173 --host\"",
    "start-backend": "node server.js",
    "start-frontend": "vite --port 5173 --host",
    "build": "vite build",
    "test": "vitest run"
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "@vitejs/plugin-react": "^4.3.1",
    "axios": "^1.13.6",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.577.0",
    "mongoose": "^7.6.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "vite": "^5.4.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "happy-dom": "^14.12.0",
    "jsdom": "^24.1.0",
    "supertest": "^7.0.0",
    "vitest": "^1.6.0"
  }
}
